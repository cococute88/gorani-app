EXPO_PUBLIC_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com
EXPO_PUBLIC_FIREBASE_DATABASE_URL=https://YOUR_PROJECT_ID-default-rtdb.firebaseio.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=YOUR_MESSAGING_SENDER_ID
EXPO_PUBLIC_FIREBASE_APP_ID=YOUR_FIREBASE_APP_ID

# 확인 필요: Firebase Auth(Google) 연동 시 일반적으로 Web Client ID를 사용합니다.
# Android OAuth Client ID와 혼동하지 마세요.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=YOUR_WEB_CLIENT_ID.apps.googleusercontent.com

# 무료 모드 일정 최신화: Polygon/Finnhub API key는 앱에 넣지 않고 Streamlit에서 처리합니다.
# 캘린더 "일정 최신화" 버튼 클릭 시 이 URL을 브라우저로 엽니다.
# 예: https://your-app.streamlit.app
EXPO_PUBLIC_STREAMLIT_CALENDAR_URL=
